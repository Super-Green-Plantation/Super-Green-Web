<?xml version="1.0" encoding="UTF-8"?>

<!--
  Thunderbird Mail Autoconfig
  Domain:      supergreenplantation.lk
  Generated:   2025
  Deploy to:   https://supergreenplantation.lk/.well-known/autoconfig/mail/config-v1.1.xml
               https://autoconfig.supergreenplantation.lk/mail/config-v1.1.xml  (fallback)
-->

<clientConfig version="1.1">
  <emailProvider id="supergreenplantation.lk">
    <domain>supergreenplantation.lk</domain>
    <displayName>Super Green Plantation Mail</displayName>
    <displayShortName>SGP Mail</displayShortName>

    <!-- ── IMAP (recommended) ── -->
    <incomingServer type="imap">
      <hostname>morgana.webserverlive.com</hostname>
      <port>993</port>
      <socketType>SSL</socketType>
      <authentication>password-cleartext</authentication>
      <username>%EMAILADDRESS%</username>
    </incomingServer>

    <!-- ── POP3 (fallback) ── -->
    <incomingServer type="pop3">
      <hostname>morgana.webserverlive.com</hostname>
      <port>995</port>
      <socketType>SSL</socketType>
      <authentication>password-cleartext</authentication>
      <username>%EMAILADDRESS%</username>
      <pop3>
        <leaveMessagesOnServer>true</leaveMessagesOnServer>
      </pop3>
    </incomingServer>

    <!-- ── SMTP ── -->
    <outgoingServer type="smtp">
      <hostname>morgana.webserverlive.com</hostname>
      <port>465</port>
      <socketType>SSL</socketType>
      <authentication>password-cleartext</authentication>
      <username>%EMAILADDRESS%</username>
    </outgoingServer>

  </emailProvider>
</clientConfig>